{
  "Logging": { "LogLevel": { "Default": "Information", "Microsoft.AspNetCore": "Warning" } },

  "ConnectionStrings": {
    "Postgres": "Host=postgres.agenthub.svc.cluster.local;Database=agenthub;Username=agenthub;Password=CHANGE_ME"
  },

  "AgentHub": {
    "Namespace": "agenthub-sessions",
    "AgentImage": "agenthub/agent-runtime:latest",
    "AgentPort": 7681,
    "GitCloneImage": "alpine/git:2.45.2",
    "ImagePullSecret": "",
    "RuntimeClassName": "",
    "MaxCpu": "2",
    "MaxMemory": "4Gi",
    "AllowCustomImage": true,
    "AllowRootSessions": true,
    "CallbackBaseUrl": "http://agenthub-backend.agenthub.svc.cluster.local",
    // Claude Code OpenTelemetry token/cost metrics export from session pods.
    // Empty TelemetryOtlpEndpoint = derive from CallbackBaseUrl (internal backend service).
    "TelemetryEnabled": false,
    "TelemetryOtlpEndpoint": ""
  },

  // S3/MinIO for session state and artifacts. Empty ServiceUrl = default AWS endpoints.
  "S3": {
    "ServiceUrl": "",
    "Region": "us-east-1",
    "Bucket": "agenthub",
    "AccessKey": "",
    "SecretKey": ""
  },

  // Optional webhook for notifications (n8n or similar). Empty = disabled.
  "N8n": {
    "WebhookUrl": ""
  },

  // Community chat integrations (no license required). Empty/disabled = off.
  "Chat": {
    "Telegram": { "Enabled": false, "BotToken": "" },
    "Signal": { "Enabled": false, "ApiUrl": "", "Number": "" }
  },

  "Ee": {
    "License": {
      // License service for checkout, seat heartbeat and token renewal. Any URL
      // configured here can only ever deliver tokens signed by the official
      // service key — the verifying public key is compiled into the binary.
      // Empty = heartbeat/checkout disabled.  [env: Ee__License__ServiceUrl]
      "ServiceUrl": "https://license.instances.open-agenthub.on-mb.com",
      "ReportIntervalHours": 24
    }
  },

  // Public URL of the frontend (CORS + links in notifications).
  "FrontendOrigin": "http://localhost:5173",

  // Generic OIDC provider (Keycloak or similar). Empty Authority = auth disabled (local development).
  // ClientId/Scope are passed through to the frontend via GET /api/config (Authorization Code + PKCE).
  "Oidc": {
    "Authority": "",
    "Audience": "agenthub",
    "RequireHttpsMetadata": true,
    "ClientId": "agenthub",
    "Scope": "openid profile email"
  }
}
